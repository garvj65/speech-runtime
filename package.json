{
  "name": "speech-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Speech Runtime Lab v0 for benchmarking VAD and ASR/STT listening quality.",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:ui": "vite --host 127.0.0.1",
    "dev:api": "tsx server/index.ts",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "example:metrics": "tsx examples/metrics-example.ts",
    "test:metrics": "tsx tests/metrics-smoke.test.ts",
    "test": "npm run typecheck && npm run test:metrics"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@types/node": "^24.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  }
}
